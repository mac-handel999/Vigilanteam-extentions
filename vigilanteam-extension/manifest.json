{
  "manifest_version": 3,
  "name": "Cyber VigilanTeam Link Shield",
  "version": "1.2",
  "description": "Automated background threat intelligence scanner with real-time injection warnings.",
  "permissions": [
    "webNavigation",
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.vercel.app/*",
    "https://api.ipinfo.io/*",
    "https://*.basemaps.cartocdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "96": "icon.png"
    }
  }
}